# Copie ce fichier en `.env` et adapte si besoin.
# Les défauts conviennent quand `tiktok-panel/` et `youtube-panel/` sont
# frères du `unified-panel/` (même dossier parent).

# Ports — le PORT public est le seul exposé (Tailscale/LAN)
PORT=3020
TT_PORT=3010
YT_PORT=3000

# Chemins vers les 2 projets que `tmux-start.sh` va orchestrer
TT_PATH=../tiktok-panel
YT_PATH=../youtube-panel

# URLs internes que le unified consomme (proxy + agrégation)
TIKTOK_URL=http://localhost:3010
YOUTUBE_URL=http://localhost:3000

# Tuning des workers — forwardé aux 2 workers (TikTok + YouTube)
SPEED_FACTOR=1.2
MAX_PARALLEL=2

# Timeout des appels vers les 2 backends (ms). Garder court : si un backend
# rame, la SPA dégrade gracieusement.
FETCH_TIMEOUT_MS=5000
