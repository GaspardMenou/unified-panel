# Copie ce fichier en `.env` et adapte les valeurs si besoin.
# Les défauts conviennent quand les 2 panels sont sur la même machine, ports standards.

PORT=3020
TIKTOK_URL=http://localhost:3010
YOUTUBE_URL=http://localhost:3000

# Timeout des appels vers les 2 backends (ms). Garder court : si un backend
# rame, la SPA dégrade gracieusement.
FETCH_TIMEOUT_MS=5000
